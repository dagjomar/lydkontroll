{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lydkontroll",
  "version": "0.1.0",
  "identifier": "no.lydkontroll.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Lydkontroll",
        "width": 1100,
        "height": 760,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "icon": ["icons/icon.icns"]
  }
}
